# Copy this file to .env and fill in your values.
# These variables are used by the CLI (python smart_crop.py).
# The GUI app stores credentials securely in the OS keychain via Settings.

# Required for the `crop` subcommand.
ANTHROPIC_API_KEY=sk-ant-...

# Optional for the `send` subcommand — avoids the interactive password prompt.
SMTP_PASSWORD=your-yahoo-app-password
